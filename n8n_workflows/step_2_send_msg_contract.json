    {
      "parameters": {
        "jsCode": "const clientPhone = $('trig_webhook_sign').item.json.body.telefono || $('trig_webhook_sign').item.json.body.telefono_cliente || '';\nconst cleanClientPhone = String(clientPhone).replace(/\\D/g, '');\n\nif (!cleanClientPhone) {\n  throw new Error(\"No se encontró el teléfono del cliente en el Webhook\");\n}\n\nlet matchedRow = null;\nfor (const item of $input.all()) {\n  const row = item.json;\n  for (const key in row) {\n    const val = row[key];\n    if (val !== null && val !== undefined) {\n      const cleanVal = String(val).replace(/\\D/g, '');\n      if (cleanVal.length >= 8 && (cleanVal.endsWith(cleanClientPhone) || cleanClientPhone.endsWith(cleanVal))) {\n        matchedRow = row;\n        break;\n      }\n    }\n  }\n  if (matchedRow) break;\n}\n\nif (!matchedRow) {\n  // Fallback: Buscar por nombre del alumno\n  const clientName = ($('trig_webhook_sign').item.json.body.nombre || '').toLowerCase().trim();\n  if (clientName) {\n    for (const item of $input.all()) {\n      const row = item.json;\n      for (const key in row) {\n        const val = row[key];\n        if (val !== null && val !== undefined && String(val).toLowerCase().includes(clientName)) {\n          matchedRow = row;\n          break;\n        }\n      }\n      if (matchedRow) break;\n    }\n  }\n}\n\nif (matchedRow) {\n  let transLink = '';\n  for (const key in matchedRow) {\n    const normKey = key.toLowerCase().normalize('NFD').replace(/[\\u0300-\\u036f]/g, '');\n    if (normKey === 'transcripcion') {\n      transLink = String(matchedRow[key]);\n      break;\n    }\n  }\n  if (!transLink) {\n    transLink = matchedRow['Transcripción'] || matchedRow['Transcripcion'] || matchedRow['transcripcion'] || '';\n  }\n  let docId = '';\n  const match = String(transLink).match(/\\/d\\/([a-zA-Z0-9-_]+)/);\n  if (match && match[1]) {\n    docId = match[1];\n  }\n  return {\n    json: {\n      ...matchedRow,\n      docId,\n      hasDoc: docId !== ''\n    }\n  };\n}\n\nreturn {\n  json: {\n    notFound: true,\n    message: `No matched row for phone ${clientPhone}`,\n    docId: '',\n    hasDoc: false\n  }\n};"
      },
