    {
      "parameters": {
        "jsCode": "const items = $input.all();\nif (items.length === 0) {\n  return { json: { documentId: '', text: '' } };\n}\nconst docData = items[0].json;\n\nfunction extractTextFromContent(contentArray) {\n  if (!contentArray || !Array.isArray(contentArray)) return '';\n  let text = '';\n  for (const element of contentArray) {\n    if (element.paragraph) {\n      if (element.paragraph.elements) {\n        for (const el of element.paragraph.elements) {\n          if (el.textRun && el.textRun.content) {\n            text += el.textRun.content;\n          }\n        }\n      }\n    } else if (element.table) {\n      if (element.table.tableRows) {\n        for (const row of element.table.tableRows) {\n          if (row.tableCells) {\n            for (const cell of row.tableCells) {\n              text += extractTextFromContent(cell.content) + ' ';\n            }\n          }\n        }\n      }\n    } else if (element.tableOfContents) {\n      text += extractTextFromContent(element.tableOfContents.content);\n    }\n  }\n  return text;\n}\n\nfunction findTabByTitle(tabs, targetTitle) {\n  if (!tabs || !Array.isArray(tabs)) return null;\n  const normalize = (str) => String(str).toLowerCase().normalize(\"NFD\").replace(/[\\u0300-\\u036f]/g, \"\").trim();\n  const targetNorm = normalize(targetTitle);\n  for (const tab of tabs) {\n    const title = (tab.tabProperties && tab.tabProperties.title) || (tab.tabHeader && tab.tabHeader.title) || '';\n    if (title) {\n      const tabNorm = normalize(title);\n      if (tabNorm === targetNorm || tabNorm.includes(targetNorm)) {\n        return tab;\n      }\n    }\n  }\n  for (const tab of tabs) {\n    if (tab.childTabs && tab.childTabs.length > 0) {\n      const found = findTabByTitle(tab.childTabs, targetTitle);\n      if (found) return found;\n    }\n  }\n  return null;\n}\n\nlet bodyToParse = null;\n\nif (docData.tabs && docData.tabs.length > 0) {\n  let targetTab = findTabByTitle(docData.tabs, 'Transcripción');\n  if (!targetTab) {\n    targetTab = findTabByTitle(docData.tabs, 'trans');\n  }\n  if (!targetTab) {\n    const findFirstDocTab = (tabsList) => {\n      for (const tab of tabsList) {\n        if (tab.documentTab && tab.documentTab.body) return tab;\n        if (tab.childTabs && tab.childTabs.length > 0) {\n          const found = findFirstDocTab(tab.childTabs);\n          if (found) return found;\n        }\n      }\n      return null;\n    };\n    targetTab = findFirstDocTab(docData.tabs);\n  }\n  if (targetTab && targetTab.documentTab && targetTab.documentTab.body) {\n    bodyToParse = targetTab.documentTab.body;\n  }\n}\n\nif (!bodyToParse && docData.body) {\n  bodyToParse = docData.body;\n}\n\nconst text = bodyToParse ? extractTextFromContent(bodyToParse.content) : '';\n\nreturn {\n  json: {\n    documentId: docData.documentId || '',\n    text: text.trim()\n  }\n};"
      },
